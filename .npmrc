# npm: tolerate the legacy MUI peer-dependency mismatches (no-op under pnpm).
legacy-peer-deps=true

# pnpm settings (npm ignores these):
# Use a flat, npm-style node_modules instead of pnpm's strict symlinked store, so
# packages that rely on hoisted/phantom deps (as they did under npm) keep working
# through the migration. Revisit once the dependency tree is clean.
node-linker=hoisted
# Mirror legacy-peer-deps: auto-install peers and don't hard-fail on mismatches.
auto-install-peers=true
strict-peer-dependencies=false
