{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["skyportal"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "SkyPortal Overview",
  "uid": "skyportal-overview",
  "panels": [
    {
      "type": "stat",
      "title": "Request rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_duration_milliseconds_count[$__rate_interval]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error rate (5xx)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_duration_milliseconds_count[$__rate_interval])), 1)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Latency p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket[$__rate_interval])) by (le))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(http_server_active_requests)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request rate by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{http_target}}",
          "expr": "topk(10, sum by (http_target) (rate(http_server_duration_milliseconds_count[$__rate_interval])))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency quantiles",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "p50",
          "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_milliseconds_bucket[$__rate_interval])) by (le))"
        },
        {
          "refId": "B",
          "legendFormat": "p95",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket[$__rate_interval])) by (le))"
        },
        {
          "refId": "C",
          "legendFormat": "p99",
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_milliseconds_bucket[$__rate_interval])) by (le))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests by status code",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{http_status_code}}",
          "expr": "sum by (http_status_code) (rate(http_server_duration_milliseconds_count[$__rate_interval]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95 by route (top 10)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{http_target}}",
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, http_target) (rate(http_server_duration_milliseconds_bucket[$__rate_interval]))))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency vs load",
      "description": "Throughput against p99 latency (right axis). Async should hold latency flatter as load rises.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99 latency" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "latency (ms)" }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "throughput",
          "expr": "sum(rate(http_server_duration_milliseconds_count[$__rate_interval]))"
        },
        {
          "refId": "B",
          "legendFormat": "p99 latency",
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_milliseconds_bucket[$__rate_interval])) by (le))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event-loop lag",
      "description": "Time the Tornado IOLoop was blocked between iterations. High lag = synchronous handlers stalling the loop; async should drive it down.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "p50",
          "expr": "histogram_quantile(0.50, sum(rate(tornado_event_loop_lag_milliseconds_bucket[$__rate_interval])) by (le))"
        },
        {
          "refId": "B",
          "legendFormat": "p95",
          "expr": "histogram_quantile(0.95, sum(rate(tornado_event_loop_lag_milliseconds_bucket[$__rate_interval])) by (le))"
        },
        {
          "refId": "C",
          "legendFormat": "p99",
          "expr": "histogram_quantile(0.99, sum(rate(tornado_event_loop_lag_milliseconds_bucket[$__rate_interval])) by (le))"
        }
      ]
    }
  ]
}
